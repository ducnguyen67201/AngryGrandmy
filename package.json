{
  "name": "grannysmith",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "dev:connected": "GRANNYSMITH_REPO_PATH=$PWD/demo GRANNYSMITH_FIX_AGENT_MODE=codex next dev -p 3000",
    "dev:demo": "pnpm --dir demo dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:e2e": "playwright test"
  },
  "dependencies": {
    "@react-three/drei": "^10.7.7",
    "@react-three/fiber": "^9.6.1",
    "lucide-react": "^1.24.0",
    "motion": "^12.42.2",
    "next": "15.5.20",
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "three": "^0.185.1",
    "zod": "^4.4.3",
    "zustand": "^5.0.14"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@vitest/coverage-v8": "4.1.10",
    "autoprefixer": "^10.4.20",
    "eslint": "^9",
    "eslint-config-next": "15.5.20",
    "jsdom": "^29.1.1",
    "playwright": "^1.61.1",
    "postcss": "^8.5.17",
    "tailwindcss": "^3.4.17",
    "typescript": "^5",
    "vitest": "^4.1.10"
  },
  "pnpm": {
    "overrides": {
      "postcss": "^8.5.17"
    }
  },
  "packageManager": "pnpm@10.23.0"
}
